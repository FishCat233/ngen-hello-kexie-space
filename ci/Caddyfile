:80 {
    root * /srv
    file_server
    encode gzip

    # 静态文件缓存
    @static {
        path *.js *.css *.woff *.woff2 *.ttf *.eot *.svg *.png *.jpg *.jpeg *.gif *.ico *.webp
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # HTML 文件不缓存
    @html {
        path *.html
    }
    header @html Cache-Control "no-cache"

    # 404 处理
    handle_errors 404 {
        respond "Not Found" 404
    }
}
